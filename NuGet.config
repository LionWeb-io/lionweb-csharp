<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<add key="bdn-nightly" value="https://www.myget.org/F/benchmarkdotnet/api/v3/index.json" />
	</packageSources>
	<packageSourceMapping>
		<packageSource key="bdn-nightly">
			<package pattern="BenchmarkDotNet" />
			<package pattern="BenchmarkDotNet.*" />
		</packageSource>
	</packageSourceMapping>
</configuration>
